/* USER CODE BEGIN Header_StartDefaultTask */
/**
  * @brief  Function implementing the defaultTask thread.
  * @param  argument: Not used
  * @retval None
  */
/* USER CODE END Header_StartDefaultTask */
void StartDefaultTask(void *argument)
{
  /* USER CODE BEGIN 5 */
  bool last_state1 = false;
  bool last_state2 = false;

  for (;;)
  {
    // ================= [1호기 제어부] =================
    bool detected1 = ReadSensor1();

    if (detected1 != last_state1)
    {
      last_state1 = detected1;
      if (detected1)
      {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_8, GPIO_PIN_SET);   // IN1 HIGH
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_9, GPIO_PIN_RESET); // IN2 LOW
        printf("[ACT1] Forward (Obstacle 1 DETECTED)\r\n");
      }
      else
      {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_8, GPIO_PIN_RESET); // IN1 LOW
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_9, GPIO_PIN_SET);   // IN2 HIGH
        printf("[ACT1] Backward (Obstacle 1 CLEAR)\r\n");
      }
    }

    // ================= [2호기 제어부] =================
    bool detected2 = ReadSensor2();

    if (detected2 != last_state2)
    {
      last_state2 = detected2;
      if (detected2)
      {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, GPIO_PIN_SET);   // IN3 HIGH
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_13, GPIO_PIN_RESET); // IN4 LOW
        printf("[ACT2] Forward (Obstacle 2 DETECTED)\r\n");
      }
      else
      {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, GPIO_PIN_RESET); // IN3 LOW
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_13, GPIO_PIN_SET);   // IN4 HIGH
        printf("[ACT2] Backward (Obstacle 2 CLEAR)\r\n");
      }
    }

    osDelay(50); // 50ms마다 센서 폴링 상태 체크
  }
  /* USER CODE END 5 */
}

