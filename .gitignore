# ============================
# autofactory-ros2 .gitignore
# ============================

# ── ROS2 ──────────────────────────────────────────
build/
install/
log/
*.egg-info/
__pycache__/
*.pyc
*.pyo
*.pyd
.colcon_build/
.colcon_ignore
*.db
COLCON_IGNORE

# ── Python ────────────────────────────────────────
*.py[cod]
*$py.class
*.so
dist/
*.egg
*.eggs/
.eggs/
.Python
env/
venv/
.venv/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── YOLO / ML ─────────────────────────────────────
# 학습 결과물 (용량 큼)
runs/
weights/
*.pt
*.onnx
*.engine
*.trt
*.pb
wandb/
mlruns/
lightning_logs/

# 데이터셋 (별도 관리)
datasets/
data/images/
data/labels/
*.cache

# ── 모방학습 ──────────────────────────────────────
demos/
trajectories/
*.pkl
*.npy
*.npz
checkpoints/
replay_buffer/

# ── STM32 / C ─────────────────────────────────────
*.o
*.obj
*.elf
*.bin
*.hex
*.map
*.lst
*.d
*.axf
*.su
STM32CubeMX/
Debug/
Release/

# ── 임베디드 IDE ──────────────────────────────────

# Keil uVision
*.uvoptx
*.uvguix
*.scvd
Listings/
Objects/

# IAR
*.ewt
*.ewd
settings/

# ── 개발환경 ──────────────────────────────────────
.env
.env.*
*.env
!.env.example
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db
*.log

# ── 기타 ──────────────────────────────────────────
*.bag          # ROS bag 파일 (용량 큼)
*.db3          # ROS2 bag db
*.yaml.bak
tmp/
temp/
*.png